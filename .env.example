# Model Configuration
CARROT_API_KEY=sk-your-api-key-here  # Required: Your OpenAI/Claude API key
CARROT_MODEL_PROVIDER=openai  # Options: openai, claude, openrouter
CARROT_MODEL_NAME=gpt-4  # Model name to use
CARROT_BASE_URL=https://api.openai.com/v1  # API base URL

# Server Configuration
CARROT_SERVER_PORT=8080  # Server port (default: 8080)
CARROT_SERVER_HOST=0.0.0.0  # Server host (default: 0.0.0.0)

# Authentication Configuration (Required for production)
CARROT_AUTH_USERNAME=admin  # Login username
CARROT_AUTH_PASSWORD=change-this-to-strong-password  # Login password (use strong password!)

# Optional: Advanced Configuration
# CARROT_LOG_LEVEL=info  # Options: debug, info, warn, error
# CARROT_DATA_DIR=~/.carrot  # Data directory path

# File Access Control (comma-separated paths)
# Add paths that the agent is allowed to access
# Example: CARROT_ALLOWED_PATHS=~/.carrot,/tmp,/Users/zhongjiaxing/Desktop
CARROT_ALLOWED_PATHS=~/.carrot,/tmp
